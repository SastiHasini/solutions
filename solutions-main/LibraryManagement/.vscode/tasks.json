{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "maven-clean-install-library-management",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Set-Location 'd:\\solutions\\LibraryManagement'; $mavenVersion = '3.9.9'; $tempRoot = Join-Path $env:TEMP \"apache-maven-$mavenVersion\"; & (Join-Path $tempRoot 'bin\\mvn.cmd') clean install"
			],
			"isBackground": false,
			"problemMatcher": [
				"$maven"
			],
			"group": "build"
		}
	]
}