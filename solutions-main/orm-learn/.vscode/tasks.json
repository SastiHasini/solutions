{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "orm-learn-build",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Set-Location 'd:\\solutions\\orm-learn'; $mavenVersion = '3.9.9'; $tempRoot = Join-Path $env:TEMP 'apache-maven-3.9.9'; & (Join-Path $tempRoot 'bin\\mvn.cmd') -B clean package"
			],
			"isBackground": false,
			"problemMatcher": [
				"$maven"
			],
			"group": "build"
		}
	]
}